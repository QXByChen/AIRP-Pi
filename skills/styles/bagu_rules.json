    {
      "id": "banned_punctuation",
      "name": "禁用标点/句式",
      "severity": "critical",
      "skip_in_dialogue": false,
      "rules": [
        {"pattern": "——", "type": "literal", "replacement": null, "hint": "删除破折号，改用逗号或句号断句"},
        {"pattern": "不是[^。！？\\n]{2,20}而是", "type": "regex", "replacement": null, "hint": "先否后肯禁止，直接写肯定表达"},
        {"pattern": "[^。！？\\n]{1,5}……不[，,]是", "type": "regex", "replacement": null, "hint": "自我纠正式转折禁止"},
        {"pattern": "(?:就像|如同|仿佛)[^。]{2,15}(?:小兽|幼兽|猎物|小猫|野兽|母兽|小动物)", "type": "regex", "replacement": null, "hint": "动物比喻禁止，直接描写状态"},
        {"pattern": "像在陈述一个事实", "type": "literal", "replacement": null, "hint": "删除此套话"},
        {"pattern": "最后一根稻草", "type": "literal", "replacement": null, "hint": "网文套话，换成具体描写"},
        {"pattern": "不容(?:置疑|拒绝|抗拒|质疑|错辨)", "type": "regex", "replacement": null, "hint": "网文套话，换成具体态度描写"}
      ]
    },
