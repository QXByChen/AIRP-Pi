{
  "provider": "deepseek",
  "model": "deepseek-v4-pro",
  "tools": ["read", "write", "edit", "bash", "grep", "glob"],
  "contextFiles": ["CLAUDE.md", "STORY.md"],
  "permissions": {
    "bash": {
      "allow": [
        "python skills/*",
        "python scripts/*",
        "node skills/*",
        "curl http://localhost:8765/*",
        "curl http://localhost:8766/*",
        "taskkill *",
        "npm install"
      ]
    }
  }
}
